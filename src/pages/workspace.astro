---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Callout from '../components/Callout.astro';
---

<BaseLayout
  title="Prompt Workspace | KeepCalmAI"
  description="Your KeepCalmAI Prompt Workspace for building, copying and saving useful AI prompts."
>
  <section class="panel workspace" aria-labelledby="workspace-title">
    <SectionHeader
      eyebrow="Prompt Workspace"
      title="Build a useful prompt"
      text="Your choices from KeepCalmAI journeys can be brought together here as a prompt you can copy, adjust and use."
    />

    <div id="workspace-empty" class="summary-box">
      <h2>No prompt parts yet</h2>
      <p>Complete the task, context, format and tone steps in Writing Better Prompts to build a prompt here.</p>
      <a class="button" href="/journeys/writing-better-prompts/">Open Writing Better Prompts</a>
    </div>

    <div id="workspace-content" class="workspace-content" hidden>
      <div class="workspace-grid">
        <article class="workspace-card">
          <p class="eyebrow">Task</p>
          <h2 id="workspace-task">Not set yet</h2>
        </article>
        <article class="workspace-card">
          <p class="eyebrow">Context</p>
          <h2 id="workspace-context">Not set yet</h2>
        </article>
        <article class="workspace-card">
          <p class="eyebrow">Format</p>
          <h2 id="workspace-format">Not set yet</h2>
        </article>
        <article class="workspace-card">
          <p class="eyebrow">Tone</p>
          <h2 id="workspace-tone">Not set yet</h2>
        </article>
      </div>

      <article class="workspace-preview" aria-labelledby="generated-prompt-title">
        <p class="eyebrow">Generated prompt</p>
        <h2 id="generated-prompt-title">Your prompt</h2>
        <p id="workspace-prompt" class="generated-prompt"></p>
        <div class="workspace-actions">
          <button id="copy-workspace-prompt" class="button" type="button">Copy prompt</button>
          <button id="save-workspace-prompt" class="button button-secondary" type="button">Save to notebook</button>
          <button id="clear-workspace" class="button button-secondary" type="button">Clear workspace</button>
          <a class="button button-secondary" href="/notebook/">Open notebook</a>
        </div>
        <p id="workspace-status" class="copy-status" role="status"></p>
      </article>
    </div>

    <Callout
      title="How this helps"
      text="The workspace turns learning choices into something practical. Instead of only learning about prompts, you gradually build one you can use."
    />
  </section>
</BaseLayout>

<script>
  import { getLearnerProfile } from '../lib/learnerProfile';
  import { buildPromptFromWorkspace, clearPromptWorkspace, saveCurrentPromptToNotebook } from '../lib/promptWorkspace';

  const profile = getLearnerProfile();
  const workspace = profile.promptWorkspace || {};
  const generatedPrompt = workspace.generatedPrompt || buildPromptFromWorkspace();
  const hasWorkspace = Boolean(generatedPrompt);

  const empty = document.querySelector('#workspace-empty');
  const content = document.querySelector('#workspace-content');
  const task = document.querySelector('#workspace-task');
  const context = document.querySelector('#workspace-context');
  const format = document.querySelector('#workspace-format');
  const tone = document.querySelector('#workspace-tone');
  const prompt = document.querySelector('#workspace-prompt');
  const copy = document.querySelector('#copy-workspace-prompt');
  const save = document.querySelector('#save-workspace-prompt');
  const clear = document.querySelector('#clear-workspace');
  const status = document.querySelector('#workspace-status');

  if (hasWorkspace) {
    if (empty) empty.hidden = true;
    if (content) content.hidden = false;
    if (task) task.textContent = workspace.task || 'Not set yet';
    if (context) context.textContent = workspace.context || 'Not set yet';
    if (format) format.textContent = workspace.format || 'Not set yet';
    if (tone) tone.textContent = workspace.tone || 'Not set yet';
    if (prompt) prompt.textContent = generatedPrompt;
  }

  copy?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(generatedPrompt || '');
      if (status) status.textContent = 'Prompt copied.';
    } catch {
      if (status) status.textContent = 'Copy was not available. Select the prompt text manually.';
    }
  });

  save?.addEventListener('click', () => {
    const before = getLearnerProfile().notebook.length;
    saveCurrentPromptToNotebook('writing-better-prompts');
    const after = getLearnerProfile().notebook.length;

    if (status) {
      status.textContent = after > before ? 'Prompt saved to notebook.' : 'There is no prompt to save yet.';
    }
  });

  clear?.addEventListener('click', () => {
    clearPromptWorkspace();
    window.location.reload();
  });
</script>
