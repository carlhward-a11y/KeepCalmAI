---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Callout from '../components/Callout.astro';
---

<BaseLayout
  title="Start | KeepCalmAI"
  description="Answer a few calm onboarding questions before starting your KeepCalmAI journey."
>
  <section class="panel onboarding" aria-labelledby="start-title">
    <SectionHeader
      eyebrow="Start calmly"
      title="Tell us what would help most"
      text="Answer three quick questions. Your answers stay on this device and help KeepCalmAI use more relevant wording."
    />

    <form id="onboarding-form" class="onboarding-form">
      <fieldset>
        <legend>Why are you here today?</legend>
        <label><input type="radio" name="goal" value="everyday" required /> Everyday life</label>
        <label><input type="radio" name="goal" value="work" /> Work</label>
        <label><input type="radio" name="goal" value="study" /> Study</label>
        <label><input type="radio" name="goal" value="curious" /> Just curious</label>
      </fieldset>

      <fieldset>
        <legend>How confident do you feel with AI?</legend>
        <label><input type="radio" name="confidence" value="new" required /> I have never used it</label>
        <label><input type="radio" name="confidence" value="tried" /> I have tried it a few times</label>
        <label><input type="radio" name="confidence" value="sometimes" /> I use it sometimes</label>
        <label><input type="radio" name="confidence" value="regular" /> I use it regularly</label>
      </fieldset>

      <fieldset>
        <legend>Which AI assistant do you use?</legend>
        <label><input type="radio" name="platform" value="ChatGPT" required /> ChatGPT</label>
        <label><input type="radio" name="platform" value="Microsoft Copilot" /> Microsoft Copilot</label>
        <label><input type="radio" name="platform" value="Google Gemini" /> Google Gemini</label>
        <label><input type="radio" name="platform" value="Claude" /> Claude</label>
        <label><input type="radio" name="platform" value="your AI assistant" /> I am not sure yet</label>
      </fieldset>

      <button class="button" type="submit">Continue to recommended journey</button>
      <p id="onboarding-status" class="copy-status" role="status"></p>
    </form>

    <Callout
      title="Why these questions matter"
      text="KeepCalmAI can adapt small wording details, such as saying 'Open ChatGPT' or 'Open Microsoft Copilot', while keeping the same calm learning route."
    />
  </section>
</BaseLayout>

<script>
  const form = document.querySelector('#onboarding-form');
  const status = document.querySelector('#onboarding-status');
  const storageKey = 'keepcalmai:onboarding';
  const saved = JSON.parse(window.localStorage.getItem(storageKey) || '{}');

  Object.entries(saved).forEach(([name, value]) => {
    const input = form?.querySelector(`input[name="${name}"][value="${value}"]`);
    if (input instanceof HTMLInputElement) {
      input.checked = true;
    }
  });

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const onboarding = {
      goal: data.get('goal'),
      confidence: data.get('confidence'),
      platform: data.get('platform')
    };

    window.localStorage.setItem(storageKey, JSON.stringify(onboarding));
    if (status) {
      status.textContent = 'Preferences saved. Opening your recommended journey.';
    }
    window.location.href = '/journeys/ai-without-overwhelm/';
  });
</script>
