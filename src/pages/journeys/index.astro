---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import JourneyCard from '../../components/JourneyCard.astro';
import ProgressResume from '../../components/ProgressResume.astro';
import JourneyMap from '../../components/JourneyMap.astro';
import { journeys } from '../../data/journeys';
import { aiWithoutOverwhelm } from '../../data/aiWithoutOverwhelm';
import { writingBetterPrompts } from '../../data/writingBetterPrompts';
import { everydayAiTasks } from '../../data/everydayAiTasks';
import { checkingAiAnswers } from '../../data/checkingAiAnswers';
---

<BaseLayout
  title="Journeys | KeepCalmAI"
  description="Browse calm, accessible AI learning journeys."
>
  <ProgressResume
    journeyId="ai-without-overwhelm"
    title="AI Without Overwhelm"
    totalSteps={aiWithoutOverwhelm.length}
    href="/journeys/ai-without-overwhelm/"
  />

  <ProgressResume
    journeyId="writing-better-prompts"
    title="Writing Better Prompts"
    totalSteps={writingBetterPrompts.length}
    href="/journeys/writing-better-prompts/"
  />

  <ProgressResume
    journeyId="everyday-ai-tasks"
    title="Everyday AI Tasks"
    totalSteps={everydayAiTasks.length}
    href="/journeys/everyday-ai-tasks/"
  />

  <ProgressResume
    journeyId="checking-ai-answers"
    title="Checking AI Answers"
    totalSteps={checkingAiAnswers.length}
    href="/journeys/checking-ai-answers/"
  />

  <JourneyMap />

  <section class="panel">
    <SectionHeader
      eyebrow="All journeys"
      title="Current journey library"
      text="Choose from the active beginner journeys below. Each one is designed to build confidence through small, practical steps."
    />
    <div class="grid">
      {journeys.map((journey) => (
        <JourneyCard
          title={journey.title}
          description={journey.description}
          estimatedTime={journey.estimatedTime}
          difficulty={journey.difficulty}
          href={journey.href}
        />
      ))}
    </div>
  </section>
</BaseLayout>
