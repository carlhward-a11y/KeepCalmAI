---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import JourneyPlayer from '../../../components/JourneyPlayer.astro';
import { aiWithoutOverwhelm } from '../../../data/aiWithoutOverwhelm';
---

<BaseLayout
  title="AI Without Overwhelm | KeepCalmAI"
  description="A calm first AI learning journey for beginners."
>
  <Hero
    eyebrow="Foundations"
    title="AI Without Overwhelm"
    text="A calm first journey for people who want to understand AI one small step at a time. The Journey Player shows one focused step at a time."
    ctaText="Begin the journey"
    ctaHref="#player"
  />

  <section class="panel" aria-labelledby="journey-map-title">
    <SectionHeader
      eyebrow="Journey player"
      title="One step at a time"
      text="Each step gives you one idea, one reason it matters, one practical action and a clear point at which to continue."
    />
  </section>

  <div id="player">
    <JourneyPlayer journeyId="ai-without-overwhelm" steps={aiWithoutOverwhelm} />
  </div>
</BaseLayout>
