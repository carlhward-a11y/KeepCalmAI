---
import BaseLayout from '../layouts/BaseLayout.astro';
import Dashboard from '../components/Dashboard.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import SectionHeader from '../components/SectionHeader.astro';

const approachFeatures = [
  {
    title: 'One idea at a time',
    text: 'Each step focuses on a single concept so the learner is not faced with a long page of information.'
  },
  {
    title: 'Try it quickly',
    text: 'Every journey includes practical activities that help the learner use AI rather than only read about it.'
  },
  {
    title: 'Confidence first',
    text: 'Progress is measured by whether the learner feels clearer, calmer and able to try the next step.'
  }
];
---

<BaseLayout
  title="KeepCalmAI | Calm Today. Confident Tomorrow."
  description="A calm, accessible way to learn AI one small step at a time."
>
  <Dashboard />

  <section class="panel" aria-labelledby="why-title">
    <SectionHeader
      eyebrow="Why KeepCalmAI?"
      title="Built for people who feel unsure, excluded or behind"
      text="Most AI training assumes confidence before it has been earned. KeepCalmAI starts from the opposite place: calm explanation, familiar examples and small practical steps."
    />
  </section>

  <section class="panel" aria-labelledby="approach-title">
    <SectionHeader
      eyebrow="The approach"
      title="Small steps, clear progress"
      text="The learning experience is designed around short journeys, practical tasks and visible progress."
    />
    <FeatureGrid features={approachFeatures} />
  </section>
</BaseLayout>
