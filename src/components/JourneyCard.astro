---
interface Props {
  title: string;
  description: string;
  estimatedTime: string;
  difficulty: string;
  href: string;
}

const { title, description, estimatedTime, difficulty, href } = Astro.props;
---

<article class="card journey-card">
  <p class="eyebrow">{difficulty} · {estimatedTime}</p>
  <h2>{title}</h2>
  <p>{description}</p>
  <a class="button" href={href}>Open journey</a>
</article>
