---
import Callout from './Callout.astro';
import ProgressBar from './ProgressBar.astro';

interface Props {
  title: string;
  time: string;
  body: string[];
  whyItMatters: string;
  actionTitle: string;
  actionSteps: string[];
  examplePrompt?: string;
  readyToContinue: string;
  takeaway: string;
  current: number;
  total: number;
}

const {
  title,
  time,
  body,
  whyItMatters,
  actionTitle,
  actionSteps,
  examplePrompt,
  readyToContinue,
  takeaway,
  current,
  total
} = Astro.props;
---

<article class="lesson-card">
  <ProgressBar current={current} total={total} />
  <p class="lesson-time">{time}</p>
  <h1>{title}</h1>
  <div class="lesson-body">
    {body.map((paragraph) => <p>{paragraph}</p>)}
  </div>

  <Callout title="Why this matters" text={whyItMatters} />

  <div class="try-box">
    <h2>{actionTitle}</h2>
    <ol class="action-list">
      {actionSteps.map((step) => <li>{step}</li>)}
    </ol>
    {examplePrompt && (
      <div class="prompt-box">
        <h3>Example prompt</h3>
        <p>{examplePrompt}</p>
      </div>
    )}
  </div>

  <Callout title="Ready to continue?" text={readyToContinue} />
  <Callout title="Key takeaway" text={takeaway} />
</article>
