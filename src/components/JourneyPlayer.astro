---
import type { LessonStep } from '../types/journey';

interface Props {
  journeyId: string;
  steps: LessonStep[];
  completeHref?: string;
}

const { journeyId, steps, completeHref = '/journeys/' } = Astro.props;
const encodedSteps = JSON.stringify(steps);
---

<section class="player" data-journey={journeyId} data-steps={encodedSteps} data-complete-href={completeHref}>
  <div class="player-toolbar">
    <p id="player-save-status" class="save-status">Progress is saved on this device.</p>
    <button id="player-reset" class="button button-secondary button-small" type="button">Start again</button>
  </div>

  <div class="progress-wrap">
    <p id="player-progress-label" class="progress-label">Step 1 of {steps.length}</p>
    <div class="progress" aria-hidden="true"><span id="player-progress-bar" style="width: 1%"></span></div>
  </div>

  <div class="player-shell">
    <article class="player-card" aria-live="polite">
      <div class="step-visual" aria-hidden="true">
        <span id="player-visual-icon">K</span>
      </div>

      <p id="player-platform" class="platform-note"></p>
      <p id="player-adaptation" class="platform-note"></p>
      <p id="player-time" class="lesson-time"></p>
      <h1 id="player-title" tabindex="-1"></h1>
      <div id="player-body" class="lesson-body"></div>

      <details id="player-why-wrap" class="detail-box">
        <summary>Why this matters</summary>
        <p id="player-why"></p>
      </details>

      <div class="try-box action-box">
        <h2 id="player-action-title"></h2>
        <ol id="player-action-list" class="action-list"></ol>
        <fieldset id="player-choice-field" class="choice-field" hidden>
          <legend>Choose one option</legend>
          <div id="player-choices" class="choice-grid"></div>
        </fieldset>
        <div id="choice-feedback" class="choice-feedback" role="status" hidden></div>
        <div id="builder-summary" class="builder-summary" hidden>
          <h3>Your prompt so far</h3>
          <p id="builder-prompt"></p>
          <button id="save-builder-prompt" class="button button-secondary button-small" type="button">Save prompt to notebook</button>
          <p id="builder-save-status" class="copy-status" role="status"></p>
        </div>
        <div id="player-prompt" class="prompt-box" hidden>
          <h3 id="prompt-heading">Ask your AI this</h3>
          <p id="player-prompt-text"></p>
          <button id="copy-prompt" class="button" type="button">Copy prompt</button>
          <p id="copy-status" class="copy-status" role="status"></p>
        </div>
      </div>

      <details class="detail-box">
        <summary>Ready to continue?</summary>
        <p id="player-ready"></p>
        <p id="choice-status" class="copy-status" role="status"></p>
      </details>

      <div class="takeaway-box">
        <h2>Key takeaway</h2>
        <p id="player-takeaway"></p>
      </div>

      <div id="reflection-box" class="takeaway-box" hidden>
        <h2>Optional reflection</h2>
        <p id="reflection-help">You can save one thought from this step if it would be useful later. This is optional.</p>
        <label for="reflection-text">A thought to keep</label>
        <textarea id="reflection-text" rows="4" aria-describedby="reflection-help"></textarea>
        <button id="save-reflection" class="button button-secondary button-small" type="button">Save reflection to notebook</button>
        <p id="reflection-status" class="copy-status" role="status"></p>
      </div>
    </article>

    <aside class="mentor-panel" aria-labelledby="mentor-title">
      <p class="eyebrow">Calm coach</p>
      <h2 id="mentor-title">Need a hand?</h2>
      <p id="mentor-message">I’ll offer a simple prompt or reassurance for this step.</p>
      <details class="mentor-detail">
        <summary>Another way to think about it</summary>
        <p id="mentor-extra">Take this one step at a time. You do not need to remember everything.</p>
      </details>
    </aside>
  </div>

  <nav class="lesson-nav" aria-label="Journey controls">
    <button id="player-back" class="button button-secondary" type="button">Back</button>
    <button id="player-next" class="button" type="button">I have done this, continue</button>
  </nav>
</section>

<script>
  import {
    addNotebookEntry,
    getJourneyProgress,
    getLearnerProfile,
    updateJourneyProgress as saveJourneyProgress,
    updateLearnerProfile,
    updatePromptWorkspace
  } from '../lib/learnerProfile';
  import { saveCurrentPromptToNotebook } from '../lib/promptWorkspace';

  const player = document.querySelector('.player');
  const steps = JSON.parse(player?.getAttribute('data-steps') || '[]');
  const journeyId = player?.getAttribute('data-journey') || '';
  const completeHref = player?.getAttribute('data-complete-href') || '/journeys/';
  const defaultReflectionPrompt = 'You can save one thought from this step if it would be useful later. This is optional.';

  function clampScore(value) {
    return Math.max(1, Math.min(10, Number(value || 1)));
  }

  function updateLearningDNA(updater) {
    updateLearnerProfile((profile) => {
      const currentDNA = profile.learningDNA;
      const nextDNA = updater(currentDNA);

      return {
        ...profile,
        learningDNA: {
          ...currentDNA,
          ...nextDNA,
          understandingAI: clampScore(nextDNA.understandingAI ?? currentDNA.understandingAI),
          promptSkills: clampScore(nextDNA.promptSkills ?? currentDNA.promptSkills),
          safetyAwareness: clampScore(nextDNA.safetyAwareness ?? currentDNA.safetyAwareness),
          confidence: clampScore(nextDNA.confidence ?? currentDNA.confidence)
        }
      };
    });
  }

  function updateLearningDNAForChoice(step, choice) {
    updateLearningDNA((dna) => {
      const nextDNA = { ...dna };
      const label = String(choice?.label || '').toLowerCase();

      if (choice?.isBest === true) nextDNA.confidence = dna.confidence + 1;
      if (choice?.isBest === false) nextDNA.needsReassurance = true;
      if (choice?.promptPart) nextDNA.promptSkills = dna.promptSkills + 1;

      if (step.id.includes('safe') || step.id.includes('privacy') || step.id.includes('check')) {
        nextDNA.safetyAwareness = dna.safetyAwareness + (choice?.isBest === true ? 2 : 0);
      }

      if (label.includes('bullet')) nextDNA.prefersBullets = true;
      if (label.includes('still unsure')) nextDNA.needsReassurance = true;

      if (label.includes('help someone else') || label.includes('could help')) {
        nextDNA.needsReassurance = false;
        nextDNA.confidence = dna.confidence + 2;
      }

      return nextDNA;
    });
  }

  function updateLearningDNAForCompletion() {
    updateLearningDNA((dna) => {
      if (journeyId === 'ai-without-overwhelm') {
        return { ...dna, understandingAI: dna.understandingAI + 2, confidence: dna.confidence + 2 };
      }

      if (journeyId === 'writing-better-prompts') {
        return { ...dna, promptSkills: dna.promptSkills + 2, confidence: dna.confidence + 1 };
      }

      return { ...dna, confidence: dna.confidence + 1 };
    });
  }

  const profile = getLearnerProfile();
  const onboarding = profile.onboarding;
  const accessibility = profile.accessibility;
  const learningDNA = profile.learningDNA;
  const platformName = onboarding.platform || 'your AI assistant';
  const initialProgress = getJourneyProgress(journeyId);
  let current = Number(initialProgress.currentStep || 0);
  let answers = initialProgress.answers || {};

  const progressLabel = document.querySelector('#player-progress-label');
  const progressBar = document.querySelector('#player-progress-bar');
  const saveStatus = document.querySelector('#player-save-status');
  const reset = document.querySelector('#player-reset');
  const visualIcon = document.querySelector('#player-visual-icon');
  const platformNote = document.querySelector('#player-platform');
  const adaptationNote = document.querySelector('#player-adaptation');
  const time = document.querySelector('#player-time');
  const title = document.querySelector('#player-title');
  const body = document.querySelector('#player-body');
  const why = document.querySelector('#player-why');
  const actionTitle = document.querySelector('#player-action-title');
  const actionList = document.querySelector('#player-action-list');
  const choiceField = document.querySelector('#player-choice-field');
  const choiceGrid = document.querySelector('#player-choices');
  const choiceFeedback = document.querySelector('#choice-feedback');
  const builderSummary = document.querySelector('#builder-summary');
  const builderPrompt = document.querySelector('#builder-prompt');
  const saveBuilderPrompt = document.querySelector('#save-builder-prompt');
  const builderSaveStatus = document.querySelector('#builder-save-status');
  const promptBox = document.querySelector('#player-prompt');
  const promptHeading = document.querySelector('#prompt-heading');
  const promptText = document.querySelector('#player-prompt-text');
  const copyButton = document.querySelector('#copy-prompt');
  const copyStatus = document.querySelector('#copy-status');
  const ready = document.querySelector('#player-ready');
  const choiceStatus = document.querySelector('#choice-status');
  const takeaway = document.querySelector('#player-takeaway');
  const reflectionBox = document.querySelector('#reflection-box');
  const reflectionHelp = document.querySelector('#reflection-help');
  const reflectionText = document.querySelector('#reflection-text');
  const saveReflection = document.querySelector('#save-reflection');
  const reflectionStatus = document.querySelector('#reflection-status');
  const back = document.querySelector('#player-back');
  const next = document.querySelector('#player-next');
  const mentorMessage = document.querySelector('#mentor-message');
  const mentorExtra = document.querySelector('#mentor-extra');

  function applyPresentationPreferences() {
    const root = document.querySelector('.player');
    if (!root) return;

    root.classList.toggle('prefers-shorter-steps', learningDNA.shorterSteps === true || accessibility.cognitiveFatigue === true || accessibility.adhd === true);
    root.classList.toggle('prefers-clear-visuals', accessibility.lowVision === true || accessibility.dyslexia === true);
    root.classList.toggle('prefers-screen-reader', accessibility.screenReader === true);

    const notes = [];
    if (learningDNA.shorterSteps || accessibility.cognitiveFatigue || accessibility.adhd) notes.push('shorter-step support is on');
    if (accessibility.lowVision || accessibility.dyslexia) notes.push('clearer visual spacing is on');
    if (accessibility.screenReader) notes.push('screen reader friendly mode is on');

    if (adaptationNote) adaptationNote.textContent = notes.length ? `Support: ${notes.join(', ')}.` : '';
  }

  function normaliseChoice(choice) {
    return typeof choice === 'string' ? { label: choice } : choice;
  }

  function personalise(text) {
    const value = String(text);
    if (platformName === 'your AI assistant') return value.replaceAll('Ask your AI this', 'Ask your AI assistant this');

    return value
      .replaceAll('your AI assistant', platformName)
      .replaceAll('AI assistant', platformName)
      .replaceAll('Ask your AI this', `Ask ${platformName} this`);
  }

  function getPromptPart(answer) {
    return answer?.promptPart || answer?.label || answer || '';
  }

  function updatePromptWorkspaceFromAnswers() {
    if (journeyId !== 'writing-better-prompts') return;

    const currentWorkspace = getLearnerProfile().promptWorkspace;
    const workspace = { ...currentWorkspace };

    ['task', 'context', 'format', 'tone'].forEach((part) => {
      const value = getPromptPart(answers[part]);
      if (value) workspace[part] = value;
    });

    workspace.generatedPrompt = [workspace.task, workspace.context, workspace.format, workspace.tone]
      .filter(Boolean)
      .join(' ')
      .trim();

    updatePromptWorkspace(workspace);
  }

  function getStepType(step) {
    if (step.type) return step.type;
    if (step.id.includes('complete')) return 'complete';
    if (step.id.includes('summary')) return 'summary';
    if (step.id.includes('check') || step.id.includes('safe') || step.id.includes('wrong')) return 'safety';
    if (step.choices?.length) return 'choice';
    if (step.examplePrompt) return 'prompt';
    return 'learn';
  }

  function getProgressLabel(step, currentIndex, total) {
    return step.progressLabel || `Step ${currentIndex + 1} of ${total}`;
  }

  function getNextButtonLabel(step, currentIndex, total) {
    return step.nextButtonLabel || (currentIndex === total - 1 ? 'Finish journey' : 'I have done this, continue');
  }

  function shouldShowReflection(step, currentIndex, total) {
    const stepType = getStepType(step);
    return stepType === 'reflection' || currentIndex === total - 1 || stepType === 'summary' || stepType === 'complete';
  }

  function getStepIcon(step) {
    if (step.choices?.length) return '✓';
    if (step.examplePrompt) return '⌘';
    if (step.id.includes('check') || step.id.includes('safe') || step.id.includes('wrong')) return '?';
    if (step.id.includes('complete') || step.id.includes('summary')) return '★';
    return 'K';
  }

  function getMentorText(step) {
    if (step.examplePrompt) {
      return {
        message: `You can copy the prompt and paste it into ${platformName}. You do not need to improve it first.`,
        extra: 'A copied prompt is a perfectly valid starting point. The skill comes from noticing the answer and asking a follow-up.'
      };
    }

    if (step.choices?.length) {
      return {
        message: learningDNA.needsReassurance === false
          ? 'Choose the strongest option. I will show guidance after you select it.'
          : 'Choose the option that feels closest. If there is a stronger answer, I will explain why after you select it.',
        extra: 'Some choices are reflective. Others are practice choices. In both cases, the aim is learning, not judgement.'
      };
    }

    if (step.id.includes('check') || step.id.includes('safe') || step.id.includes('wrong')) {
      return {
        message: 'This step is about safe confidence. AI can be useful, but important answers still need checking.',
        extra: 'A calm safety habit is simple: use AI to help you think, then check anything important before acting on it.'
      };
    }

    if (step.id.includes('complete') || step.id.includes('summary')) {
      return {
        message: 'You have done enough for this journey. The aim is not perfection, it is a small useful step forward.',
        extra: 'Confidence grows when you repeat small actions. One practical use this week is enough.'
      };
    }

    if (accessibility.cognitiveFatigue && current > 0 && current % 10 === 0) {
      return {
        message: 'You have reached a sensible pause point. It is fine to stop here and return later.',
        extra: 'Progress is saved automatically on this device.'
      };
    }

    return {
      message: learningDNA.shorterSteps || accessibility.adhd
        ? 'Focus on the action for this screen. That is enough for now.'
        : 'Take this screen slowly. Read the main idea, do the one action, then continue when it feels clear enough.',
      extra: 'You do not need to remember every word. KeepCalmAI is designed so the next step carries you forward.'
    };
  }

  function saveAnswers() {
    saveJourneyProgress(journeyId, { currentStep: current, answers });
    updatePromptWorkspaceFromAnswers();
    saveStatus.textContent = 'Choice saved on this device.';
  }

  function saveProgress() {
    saveJourneyProgress(journeyId, { currentStep: current, answers });
    saveStatus.textContent = current === 0 ? 'Progress is saved on this device.' : `Progress saved: step ${current + 1}.`;
  }

  function updateChoiceFeedback(choice) {
    if (!choice || !choice.feedback) {
      choiceFeedback.hidden = true;
      choiceFeedback.textContent = '';
      choiceFeedback.classList.remove('is-best', 'is-developing');
      return;
    }

    choiceFeedback.hidden = false;
    choiceFeedback.textContent = personalise(choice.feedback);
    choiceFeedback.classList.toggle('is-best', choice.isBest === true);
    choiceFeedback.classList.toggle('is-developing', choice.isBest !== true);
  }

  function updateBuilderSummary() {
    const parts = [answers.task, answers.context, answers.format, answers.tone]
      .map((answer) => answer?.promptPart || answer?.label || answer)
      .filter(Boolean);

    if (!parts.length || !['build-prompt', 'personal-prompt', 'summary'].includes(steps[current].id)) {
      builderSummary.hidden = true;
      builderPrompt.textContent = '';
      if (builderSaveStatus) builderSaveStatus.textContent = '';
      return;
    }

    builderSummary.hidden = false;
    builderPrompt.textContent = personalise(parts.join(' '));
  }

  function updateReflectionBox(step) {
    if (!reflectionBox || !reflectionText || !reflectionStatus) return;
    reflectionBox.hidden = !shouldShowReflection(step, current, steps.length);
    if (reflectionHelp) reflectionHelp.textContent = personalise(step.reflectionPrompt || defaultReflectionPrompt);
    reflectionStatus.textContent = '';
    if (reflectionText instanceof HTMLTextAreaElement) reflectionText.value = '';
  }

  function renderChoices(step) {
    choiceGrid.innerHTML = '';
    choiceStatus.textContent = '';

    if (!step.choices || step.choices.length === 0) {
      choiceField.hidden = true;
      updateChoiceFeedback(null);
      return;
    }

    choiceField.hidden = false;
    const selected = answers[step.id]?.label || answers[step.id];
    const selectedChoice = step.choices.map(normaliseChoice).find((choice) => choice.label === selected);
    updateChoiceFeedback(selectedChoice);

    step.choices.map(normaliseChoice).forEach((choice, index) => {
      const id = `choice-${step.id}-${index}`;
      const label = document.createElement('label');
      label.className = 'choice-card';
      label.setAttribute('for', id);

      const input = document.createElement('input');
      input.type = 'radio';
      input.id = id;
      input.name = `choice-${step.id}`;
      input.value = choice.label;
      input.checked = selected === choice.label;

      const span = document.createElement('span');
      span.textContent = personalise(choice.label);

      input.addEventListener('change', () => {
        answers[step.id] = choice;
        saveAnswers();
        updateLearningDNAForChoice(step, choice);
        updateChoiceFeedback(choice);
        updateBuilderSummary();
        choiceStatus.textContent = choice.isBest === false ? 'Choice saved. Read the guidance above before continuing.' : 'Choice saved.';
      });

      label.append(input, span);
      choiceGrid.append(label);
    });
  }

  function render() {
    const step = steps[current];
    const progress = Math.round(((current + 1) / steps.length) * 100);
    const mentor = getMentorText(step);

    progressLabel.textContent = personalise(getProgressLabel(step, current, steps.length));
    progressBar.style.width = `${progress}%`;
    visualIcon.textContent = getStepIcon(step);
    platformNote.textContent = platformName === 'your AI assistant' ? '' : `Using: ${platformName}`;
    time.textContent = step.time;
    title.textContent = personalise(step.title);
    body.innerHTML = step.body.map((paragraph) => `<p>${personalise(paragraph)}</p>`).join('');
    why.textContent = personalise(step.whyItMatters);
    actionTitle.textContent = personalise(step.actionTitle);
    actionList.innerHTML = step.actionSteps.map((item) => `<li>${personalise(item)}</li>`).join('');
    ready.textContent = personalise(step.readyToContinue);
    takeaway.textContent = personalise(step.takeaway);
    mentorMessage.textContent = personalise(mentor.message);
    mentorExtra.textContent = personalise(mentor.extra);
    renderChoices(step);
    updateBuilderSummary();
    updateReflectionBox(step);

    if (step.examplePrompt) {
      promptBox.hidden = false;
      promptHeading.textContent = `Ask ${platformName} this`;
      promptText.textContent = personalise(step.examplePrompt);
      copyStatus.textContent = '';
    } else {
      promptBox.hidden = true;
      promptText.textContent = '';
    }

    back.disabled = current === 0;
    next.textContent = personalise(getNextButtonLabel(step, current, steps.length));
    saveProgress();
    title.focus();
  }

  back.addEventListener('click', () => {
    if (current > 0) {
      current -= 1;
      render();
    }
  });

  next.addEventListener('click', () => {
    if (current < steps.length - 1) {
      current += 1;
      render();
    } else {
      saveJourneyProgress(journeyId, { currentStep: current, answers, complete: true });
      updateLearningDNAForCompletion();
      window.location.href = completeHref;
    }
  });

  reset.addEventListener('click', () => {
    current = 0;
    answers = {};
    saveJourneyProgress(journeyId, { currentStep: 0, complete: false, answers: {} });
    render();
  });

  copyButton.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(promptText.textContent || '');
      copyStatus.textContent = 'Prompt copied.';
    } catch {
      copyStatus.textContent = 'Copy was not available. Select the prompt text manually.';
    }
  });

  saveBuilderPrompt.addEventListener('click', () => {
    updatePromptWorkspaceFromAnswers();
    const before = getLearnerProfile().notebook.length;
    saveCurrentPromptToNotebook(journeyId, steps[current]?.id);
    const after = getLearnerProfile().notebook.length;

    if (builderSaveStatus) {
      builderSaveStatus.textContent = after > before
        ? 'Prompt saved to notebook.'
        : 'This prompt is already in your notebook.';
    }
  });

  saveReflection.addEventListener('click', () => {
    if (!(reflectionText instanceof HTMLTextAreaElement) || !reflectionStatus) return;

    const content = reflectionText.value.trim();
    if (!content) {
      reflectionStatus.textContent = 'Nothing has been saved yet. Add a short thought if you would like to keep one.';
      return;
    }

    addNotebookEntry({
      type: 'reflection',
      title: 'Learning reflection',
      content,
      journeyId,
      stepId: steps[current]?.id
    });

    reflectionText.value = '';
    reflectionStatus.textContent = 'Reflection saved to notebook.';
  });

  applyPresentationPreferences();
  render();
</script>
