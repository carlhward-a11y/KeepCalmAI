---
import ProgressResume from './ProgressResume.astro';
import Achievements from './Achievements.astro';
import { aiWithoutOverwhelm } from '../data/aiWithoutOverwhelm';
import { writingBetterPrompts } from '../data/writingBetterPrompts';
import { everydayAiTasks } from '../data/everydayAiTasks';
import { checkingAiAnswers } from '../data/checkingAiAnswers';

const firstJourneyTotal = aiWithoutOverwhelm.length;
const promptJourneyTotal = writingBetterPrompts.length;
const everydayJourneyTotal = everydayAiTasks.length;
const checkingJourneyTotal = checkingAiAnswers.length;
---

<section class="dashboard" aria-labelledby="dashboard-title">
  <div class="dashboard-hero">
    <p id="dashboard-greeting" class="eyebrow">Welcome back</p>
    <h1 id="dashboard-title">Your calm AI learning space</h1>
    <p id="dashboard-intro" class="lead">Continue where you left off, or start with the first guided journey.</p>
    <div class="dashboard-actions">
      <a class="button" href="/start/">Start setup</a>
      <a class="button button-secondary" href="/journeys/">View journeys</a>
    </div>
  </div>

  <ProgressResume
    journeyId="ai-without-overwhelm"
    title="AI Without Overwhelm"
    totalSteps={firstJourneyTotal}
    href="/journeys/ai-without-overwhelm/"
  />

  <ProgressResume
    journeyId="writing-better-prompts"
    title="Writing Better Prompts"
    totalSteps={promptJourneyTotal}
    href="/journeys/writing-better-prompts/"
  />

  <ProgressResume
    journeyId="everyday-ai-tasks"
    title="Everyday AI Tasks"
    totalSteps={everydayJourneyTotal}
    href="/journeys/everyday-ai-tasks/"
  />

  <ProgressResume
    journeyId="checking-ai-answers"
    title="Checking AI Answers"
    totalSteps={checkingJourneyTotal}
    href="/journeys/checking-ai-answers/"
  />

  <div class="dashboard-grid">
    <article class="metric-card">
      <p class="eyebrow">Current journey</p>
      <h2 id="dashboard-current-title">AI Without Overwhelm</h2>
      <p id="dashboard-current-status">Ready to begin.</p>
    </article>

    <article class="metric-card">
      <p class="eyebrow">Confidence</p>
      <h2 id="dashboard-confidence">Starting gently</h2>
      <p id="dashboard-confidence-text">Confidence grows through repeated small steps.</p>
    </article>

    <article class="metric-card">
      <p class="eyebrow">Next recommended step</p>
      <h2 id="dashboard-next-title">Writing Better Prompts</h2>
      <p id="dashboard-next-text">Build on the first journey by learning a simple prompt structure.</p>
      <a id="dashboard-next-link" class="button" href="/journeys/writing-better-prompts/">Open next journey</a>
    </article>
  </div>

  <section class="dna-panel" aria-labelledby="dna-title">
    <div class="section-header">
      <p class="eyebrow">Learning DNA</p>
      <h2 id="dna-title">Your confidence picture</h2>
      <p class="lead">These are gentle indicators, not scores or tests. They help KeepCalmAI understand what support may be useful next.</p>
    </div>
    <div class="dna-grid">
      <article class="dna-card">
        <span>Understanding AI</span>
        <strong id="dna-understanding">1 / 10</strong>
      </article>
      <article class="dna-card">
        <span>Prompt skills</span>
        <strong id="dna-prompts">1 / 10</strong>
      </article>
      <article class="dna-card">
        <span>Safety awareness</span>
        <strong id="dna-safety">1 / 10</strong>
      </article>
      <article class="dna-card">
        <span>Confidence</span>
        <strong id="dna-confidence">1 / 10</strong>
      </article>
    </div>
    <p id="dna-preferences" class="platform-note"></p>
  </section>

  <Achievements />
</section>

<script define:vars={{ firstJourneyTotal, promptJourneyTotal, everydayJourneyTotal, checkingJourneyTotal }}>
  function getLearnerProfile() {
    const defaultProfile = {
      onboarding: {},
      journeys: {},
      learningDNA: {
        understandingAI: 1,
        promptSkills: 1,
        safetyAwareness: 1,
        confidence: 1,
        prefersBullets: false,
        needsReassurance: true,
        shorterSteps: false
      }
    };
    const raw = window.localStorage.getItem('keepcalmai:learner-profile');

    try {
      return raw ? { ...defaultProfile, ...JSON.parse(raw) } : defaultProfile;
    } catch {
      return defaultProfile;
    }
  }

  const profile = getLearnerProfile();
  const onboarding = profile.onboarding || {};
  const dna = {
    understandingAI: 1,
    promptSkills: 1,
    safetyAwareness: 1,
    confidence: 1,
    prefersBullets: false,
    needsReassurance: true,
    shorterSteps: false,
    ...(profile.learningDNA || {})
  };
  const first = profile.journeys?.['ai-without-overwhelm'];
  const prompts = profile.journeys?.['writing-better-prompts'];
  const everyday = profile.journeys?.['everyday-ai-tasks'];
  const checking = profile.journeys?.['checking-ai-answers'];
  const firstCurrent = Number(first?.currentStep || 0);
  const firstComplete = first?.complete === true;
  const promptCurrent = Number(prompts?.currentStep || 0);
  const promptComplete = prompts?.complete === true;
  const everydayCurrent = Number(everyday?.currentStep || 0);
  const everydayComplete = everyday?.complete === true;
  const checkingCurrent = Number(checking?.currentStep || 0);
  const checkingComplete = checking?.complete === true;

  const greeting = document.querySelector('#dashboard-greeting');
  const intro = document.querySelector('#dashboard-intro');
  const currentTitle = document.querySelector('#dashboard-current-title');
  const status = document.querySelector('#dashboard-current-status');
  const confidence = document.querySelector('#dashboard-confidence');
  const confidenceText = document.querySelector('#dashboard-confidence-text');
  const nextTitle = document.querySelector('#dashboard-next-title');
  const nextText = document.querySelector('#dashboard-next-text');
  const nextLink = document.querySelector('#dashboard-next-link');
  const dnaUnderstanding = document.querySelector('#dna-understanding');
  const dnaPrompts = document.querySelector('#dna-prompts');
  const dnaSafety = document.querySelector('#dna-safety');
  const dnaConfidence = document.querySelector('#dna-confidence');
  const dnaPreferences = document.querySelector('#dna-preferences');

  if (onboarding.platform && greeting) {
    greeting.textContent = `Welcome back, ${onboarding.platform} learner`;
  }

  if (onboarding.goal && intro) {
    const goalMap = {
      everyday: 'Everyday AI can feel manageable when you learn one small action at a time.',
      work: 'Workplace AI feels easier when each step is practical and relevant.',
      study: 'Study with AI works best when you build calm habits first.',
      curious: 'Curiosity is a good enough reason to start.'
    };
    intro.textContent = goalMap[onboarding.goal] || intro.textContent;
  }

  if (currentTitle && status) {
    if (checkingComplete) {
      currentTitle.textContent = 'Checking AI Answers';
      status.textContent = 'Completed. You have finished the current beginner journey set.';
    } else if (checkingCurrent > 0 || everydayComplete) {
      currentTitle.textContent = 'Checking AI Answers';
      status.textContent = checkingCurrent > 0
        ? `In progress. You are on step ${checkingCurrent + 1} of ${checkingJourneyTotal}.`
        : 'Recommended next. Ready to begin.';
    } else if (everydayCurrent > 0 || promptComplete) {
      currentTitle.textContent = 'Everyday AI Tasks';
      status.textContent = everydayCurrent > 0
        ? `In progress. You are on step ${everydayCurrent + 1} of ${everydayJourneyTotal}.`
        : 'Recommended next. Ready to begin.';
    } else if (promptCurrent > 0 || firstComplete) {
      currentTitle.textContent = 'Writing Better Prompts';
      status.textContent = promptCurrent > 0
        ? `In progress. You are on step ${promptCurrent + 1} of ${promptJourneyTotal}.`
        : 'Recommended next. Ready to begin.';
    } else {
      currentTitle.textContent = 'AI Without Overwhelm';
      status.textContent = firstCurrent > 0
        ? `In progress. You are on step ${firstCurrent + 1} of ${firstJourneyTotal}.`
        : 'Ready to begin.';
    }
  }

  if (confidence && confidenceText) {
    if (checkingComplete) {
      confidence.textContent = 'Four journeys complete';
      confidenceText.textContent = 'You have completed the current beginner journey set.';
    } else if (everydayComplete) {
      confidence.textContent = 'Three journeys complete';
      confidenceText.textContent = 'You have completed the first three beginner journeys.';
    } else if (promptComplete) {
      confidence.textContent = 'Two journeys complete';
      confidenceText.textContent = 'You have completed the foundations and prompt skills journeys.';
    } else if (firstComplete) {
      confidence.textContent = 'Foundation complete';
      confidenceText.textContent = 'You have completed the first confidence-building journey.';
    } else if (firstCurrent > Math.floor(firstJourneyTotal / 2)) {
      confidence.textContent = 'Growing steadily';
      confidenceText.textContent = 'You have already completed more than half of the first journey.';
    } else if (firstCurrent > 0) {
      confidence.textContent = 'In progress';
      confidenceText.textContent = 'You have started. That is the most important step.';
    }
  }

  if (nextTitle && nextText && nextLink) {
    if (checkingComplete) {
      nextTitle.textContent = 'Review your notebook';
      nextText.textContent = 'Review saved prompts and reflections, or repeat a journey when it would be useful.';
      nextLink.textContent = 'Open notebook';
      nextLink.setAttribute('href', '/notebook/');
    } else if (everydayComplete) {
      nextTitle.textContent = 'Checking AI Answers';
      nextText.textContent = 'Build calm habits for checking important AI answers before relying on them.';
      nextLink.textContent = 'Open next journey';
      nextLink.setAttribute('href', '/journeys/checking-ai-answers/');
    } else if (promptComplete) {
      nextTitle.textContent = 'Everyday AI Tasks';
      nextText.textContent = 'Use AI for simple daily lists, steps, messages and safer checking habits.';
      nextLink.textContent = 'Open next journey';
      nextLink.setAttribute('href', '/journeys/everyday-ai-tasks/');
    } else if (!firstComplete) {
      nextTitle.textContent = 'AI Without Overwhelm';
      nextText.textContent = 'Start here before moving into prompt skills.';
      nextLink.textContent = 'Open first journey';
      nextLink.setAttribute('href', '/journeys/ai-without-overwhelm/');
    }
  }

  if (dnaUnderstanding) dnaUnderstanding.textContent = `${dna.understandingAI} / 10`;
  if (dnaPrompts) dnaPrompts.textContent = `${dna.promptSkills} / 10`;
  if (dnaSafety) dnaSafety.textContent = `${dna.safetyAwareness} / 10`;
  if (dnaConfidence) dnaConfidence.textContent = `${dna.confidence} / 10`;

  if (dnaPreferences) {
    const preferences = [];
    if (dna.prefersBullets) preferences.push('prefers bullet points');
    if (dna.shorterSteps) preferences.push('prefers shorter steps');
    if (dna.needsReassurance) preferences.push('benefits from reassurance');
    dnaPreferences.textContent = preferences.length ? `Current preferences: ${preferences.join(', ')}.` : '';
  }
</script>
